# ============================================================
# AI Commerce OS — Environment Variables
# Copy to .env and fill in real values for local development
# ============================================================

# === Database (Postgres) ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aicommerce
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aicommerce

# === Redis ===
REDIS_URL=redis://localhost:6379

# === Auth / JWT ===
JWT_SECRET=change-me-in-production-minimum-32-characters
JWT_EXPIRES_IN=24h
NEXTAUTH_SECRET=change-me-nextauth-secret-minimum-32-chars
NEXTAUTH_URL=http://localhost:3000

# === S3 / MinIO (object storage) ===
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ai-commerce-os
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# === Service URLs ===
API_URL=http://localhost:4000
AGENT_SERVICE_URL=http://localhost:8000
DASHBOARD_URL=http://localhost:3000

# === Observability (OpenTelemetry) ===
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=ai-commerce-os

# === Feature Flags ===
DRY_RUN=true
ENABLE_RLS=false

# === CORS ===
CORS_ORIGIN=http://localhost:3000

# === Rate Limiting ===
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# === Environment ===
NODE_ENV=development
LOG_LEVEL=debug
