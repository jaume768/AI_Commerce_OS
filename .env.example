# ============================================================
# AI Commerce OS — Environment Variables
# Copy to .env and fill in real values for local development
# ============================================================

# === Database (Postgres) ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aicommerce
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aicommerce

# === Redis ===
REDIS_URL=redis://localhost:6379

# === Auth / JWT ===
JWT_SECRET=change-me-in-production-minimum-32-characters
JWT_EXPIRES_IN=24h
NEXTAUTH_SECRET=change-me-nextauth-secret-minimum-32-chars
NEXTAUTH_URL=http://localhost:3000

# === S3 / MinIO (object storage) ===
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ai-commerce-os
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# === Service URLs ===
API_URL=http://localhost:4000
AGENT_SERVICE_URL=http://localhost:8000
DASHBOARD_URL=http://localhost:3000

# === Observability (OpenTelemetry) ===
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=ai-commerce-os

# === Shopify ===
SHOPIFY_SHOP_DOMAIN=tu-tienda.myshopify.com
SHOPIFY_API_VERSION=2024-10
# Option A — Legacy custom app (static token):
# SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Option B — Dev Dashboard app (client credentials, token auto-refresh):
SHOPIFY_CLIENT_ID=your_client_id
SHOPIFY_CLIENT_SECRET=your_client_secret

# === Tracking — Fase 3 ===
TRACKING_ENABLED=false
STORE_URL=https://tu-tienda.myshopify.com

# Meta (Facebook/Instagram) — Conversions API
# Get these from Meta Events Manager > Data Sources > Your Pixel > Settings
META_PIXEL_ID=your_meta_pixel_id
META_ACCESS_TOKEN=your_meta_system_user_token
META_API_VERSION=v21.0
# Set a test event code from Meta Events Manager > Test Events tab (for dev only):
# META_TEST_EVENT_CODE=TEST12345

# TikTok — Events API
# Get these from TikTok Events Manager > Your Pixel > Settings
# TIKTOK_PIXEL_ID=your_tiktok_pixel_id
# TIKTOK_ACCESS_TOKEN=your_tiktok_access_token
# TIKTOK_TEST_EVENT_CODE=TEST_CODE

# === Fase 6 — Agents ===

# LLM Provider: anthropic | openai | mock
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3

# Internal service-to-service auth (JWT token for agent-service → api-node)
API_NODE_TOKEN=

# Internal auth token — api-node sends this to agent-service to authenticate requests
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_AUTH_TOKEN=change-me-in-production-minimum-32-characters

# Scheduler (runs daily agents: reporting + support email check)
SCHEDULER_ENABLED=false
REPORTING_SCHEDULE_HOUR=9
REPORTING_SCHEDULE_MINUTE=0
SUPPORT_EMAIL_SCHEDULE_HOUR=8
SUPPORT_EMAIL_SCHEDULE_MINUTE=30

# Email — IMAP (SupportAgent reads incoming emails)
# Use your store's support email credentials
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_USE_SSL=true
IMAP_FOLDER=INBOX

# Email — SMTP (SupportAgent sends auto-reply acknowledgments)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_NAME=Soporte
SMTP_FROM_ADDRESS=

# Agent thresholds
OPS_HIGH_VALUE_THRESHOLD=150.0
OPS_UNPAID_HOURS_THRESHOLD=24

# === Feature Flags ===
DRY_RUN=true
ENABLE_RLS=false

# === CORS ===
CORS_ORIGIN=http://localhost:3000

# === Rate Limiting ===
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# === Environment ===
NODE_ENV=development
LOG_LEVEL=debug
